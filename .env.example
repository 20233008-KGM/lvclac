# Supabase auth/DB.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-public-key
#
# Auth transactional email (Resend + Supabase custom SMTP) is configured in the
# Supabase dashboard, not in client .env. See docs/auth-email-setup.md.
# RESEND_API_KEY=re_...  # server-only, only if you send mail from Vercel API later

# Server-only Supabase service role key.
# Used by local dev reset and billing webhook sync. Do not expose this in client code.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Server-only Vercel Cron bearer token for /api/cron/account-snapshots.
# Vercel sends this automatically as Authorization: Bearer <CRON_SECRET>.
# CRON_SECRET=replace-with-a-random-string

# Paddle Billing subscriptions.
# Server secrets must not use VITE_. Only VITE_PADDLE_CLIENT_TOKEN may be exposed to the client.
# PADDLE_API_KEY, PADDLE_WEBHOOK_SECRET, and SUPABASE_SERVICE_ROLE_KEY are server-only values.
# PADDLE_API_KEY=pdl_...
# PADDLE_WEBHOOK_SECRET=pdl_ntfset_...
# PADDLE_ENV=sandbox
# PADDLE_PRICE_MONTHLY=pri_xxx
# PADDLE_PRICE_YEARLY=pri_xxx
# VITE_PADDLE_CLIENT_TOKEN=test_xxx
# VITE_PADDLE_ENV=sandbox
# APP_URL=https://your-domain.com

# Google AdSense. If unset, ad placeholders are shown.
# VITE_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
# VITE_AD_SLOT_LEFT_SIDEBAR_TOP=1234567890
# VITE_AD_SLOT_LEFT_SIDEBAR_BOTTOM=1234567891
# VITE_AD_SLOT_TOP_BANNER=1234567892
# VITE_AD_SLOT_BOTTOM_BANNER=1234567893
# VITE_AD_SLOT_RIGHT_SIDEBAR_TOP=1234567894
# VITE_AD_SLOT_RIGHT_SIDEBAR_BOTTOM=1234567895

# Post-launch optimization flag for taller sidebar ads.
# VITE_AD_ENABLE_SIDEBAR_TALL=false

# Google Analytics 4. If unset, tracking is disabled.
# VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Public site URL for sitemap.xml and og:url.
# VITE_SITE_URL=https://your-domain.com

# Search engine indexing. Default is blocked unless true.
# ALLOW_INDEXING=true
