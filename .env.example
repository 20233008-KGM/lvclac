# Supabase 인증/DB. URL과 ANON_KEY가 모두 있어야 로그인이 활성화됩니다.
# (Settings → API 에서 확인) anon key는 공개돼도 안전한 공개키입니다 — service_role 키는 절대 프론트에 넣지 마세요.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-public-key

# [개발 전용] 마이페이지 "테스트 계정 초기화" 버튼용 service_role 키.
# 비-VITE 접두사라 클라이언트 번들에 노출되지 않으며, Vite dev 서버(npm run dev)에서만 사용됩니다.
# 로컬 .env 에만 채우고 절대 커밋/배포하지 마세요.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Google AdSense (설정하지 않으면 광고 placeholder가 표시됩니다)
# VITE_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
# VITE_AD_SLOT_LEFT_SIDEBAR_TOP=1234567890
# VITE_AD_SLOT_LEFT_SIDEBAR_BOTTOM=1234567891
# VITE_AD_SLOT_TOP_BANNER=1234567892
# VITE_AD_SLOT_BOTTOM_BANNER=1234567893
# VITE_AD_SLOT_RIGHT_SIDEBAR_TOP=1234567894
# VITE_AD_SLOT_RIGHT_SIDEBAR_BOTTOM=1234567895

# 출시 2~4주 후 이탈률·RPM이 낮으면 sidebar-tall 슬롯 비활성화 (6→4슬롯)
# VITE_AD_ENABLE_SIDEBAR_TALL=false

# Google Analytics 4 (설정하지 않으면 추적 비활성)
# VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# 배포 후 sitemap.xml·og:url에 절대 URL이 필요하면 설정 (예: https://your-domain.com)
# VITE_SITE_URL=https://your-domain.com

# 검색엔진 색인 허용 (기본: 차단). 정식 런칭 시 Vercel 환경변수에 true 설정 후 재배포
# ALLOW_INDEXING=true
