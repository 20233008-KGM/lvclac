  it('disables unlink and warns when Google is the only login method', () => {
    const html = renderToStaticMarkup(
      <MyPageView
        {...baseProps}
        user={{ id: 'user-1', email: 'user@example.com', nickname: 'Trader Kim', autoSaveOrderHistory: true, isAdmin: false }}
        linkedProviders={['google']}
      />,
    )

    expect(html).toContain(en.myPage.unlinkGoogleAction)
    expect(html).toContain(en.myPage.lastIdentityNote)
    expect(html).toContain('disabled=""')
    expect(html).toContain(`>${en.myPage.setPasswordAction}</button>`)
    // Google-only 사용자는 이메일 수단이 미연동 → '기본' 칩 없음
    expect(html).toContain('my-page-linked-badge is-unlinked')
    expect(html).not.toContain(`my-page-linked-chip">${en.myPage.primaryTag}`)
  })

  it('renders the set-password form when Google is the only linked provider and the form is open', () => {
    const html = renderToStaticMarkup(
      <MyPageView
        {...baseProps}
        user={{ id: 'user-1', email: 'user@example.com', nickname: 'Trader Kim', autoSaveOrderHistory: true, isAdmin: false }}
        linkedProviders={['google']}
        passwordFormOpen
        passwordDraft="secret123"
        passwordConfirmationDraft="secret123"
      />,
    )

    expect(html).toContain('id="my-page-set-password-form"')
    expect(html).toContain('value="user@example.com"')
    expect(html).toContain(en.myPage.setPasswordEmailHelp)
    expect(html).toContain(en.myPage.savePassword)
    expect(html).not.toContain(`>${en.myPage.linkGoogleAction}</button>`)
  })

  it('does not offer set-password when email login is already linked', () => {
    const html = renderToStaticMarkup(
      <MyPageView
        {...baseProps}
        user={{ id: 'user-1', email: 'user@example.com', nickname: 'Trader Kim', autoSaveOrderHistory: true, isAdmin: false }}
        linkedProviders={['email']}
      />,
    )

    expect(html).not.toContain(`>${en.myPage.setPasswordAction}</button>`)
    expect(html).not.toContain('id="my-page-set-password-form"')
  })