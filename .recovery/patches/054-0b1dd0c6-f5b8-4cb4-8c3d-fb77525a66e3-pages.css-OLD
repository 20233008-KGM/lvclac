.my-page-panel h2,
.my-page-delete-note h3 {
  margin: 0;
  color: var(--color-text);
}

/* Blue left-accent title, consistent with the app's other pages (.guide-panel__title). */
.my-page-panel h2 {
  padding-left: 0.7rem;
  border-left: 3px solid var(--color-primary);
  font-size: 1.1rem;
  line-height: 1.3;
}

.my-page-delete-note h3 {
  font-size: var(--font-size-base);
}