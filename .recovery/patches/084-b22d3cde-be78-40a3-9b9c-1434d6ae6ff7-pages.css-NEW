.my-page-panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
}

.my-page-account-email {
  margin: 4px 0 0;
  padding-left: 0.7rem;
  color: var(--color-text-muted);
  font-size: var(--font-size-sm);
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}